<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="260dp"
    android:orientation="vertical"
    android:background="@color/ime_keyboard_bg"
    android:padding="8dp">

    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="@color/ime_candidate_text"
        android:padding="8dp"
        android:gravity="center" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/dit_btn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="@color/ime_button_bg"
            android:textColor="@color/ime_button_text"
            android:text="DIT"
            android:textSize="28sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/dah_btn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:backgroundTint="@color/ime_button_bg"
            android:textColor="@color/ime_button_text"
            android:text="DAH"
            android:textSize="28sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
